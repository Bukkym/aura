# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and will not be committed.

# OpenAI API key — used for Whisper (transcription),
# embeddings (text-embedding-3-small), and chat (extraction + plan generation).
OPENAI_API_KEY=

# Supabase — project URL and the two API keys.
# Publishable key is browser-safe (RLS gates every query).
# Secret key is server-only — never import it into a Client Component.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Postgres connection strings, both pointing at the same Supabase project.
# DATABASE_URL is the pooled connection (port 6543), used at runtime.
# DIRECT_URL is the direct connection (port 5432), used by migrations only.
DATABASE_URL=
DIRECT_URL=
